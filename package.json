{
  "name": "clod",
  "version": "0.1.0",
  "description": "Clod — Command Line User Interface for Claude Code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/misha-park/clod.git"
  },
  "bugs": {
    "url": "https://github.com/misha-park/clod/issues"
  },
  "homepage": "https://github.com/misha-park/clod#readme",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "electron-vite preview",
    "dist": "bash scripts/build-native.sh && electron-vite build --mode production && electron-builder --mac --dir",
    "build:native": "bash scripts/build-native.sh",
    "doctor": "bash scripts/doctor.sh",
    "postinstall": "electron-builder install-app-deps && bash scripts/patch-dev-icon.sh && bash scripts/build-native.sh"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "framer-motion": "^12.35.1",
    "katex": "^0.17.0",
    "node-pty": "^1.1.0",
    "react-markdown": "^9.0.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "uiohook-napi": "^1.5.5",
    "use-sync-external-store": "^1.6.0",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.clod.app",
    "productName": "Clod",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "resources/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "resources/native/**"
    ],
    "mac": {
      "identity": "Clod Code Signing",
      "icon": "resources/icon.icns",
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Clod uses your microphone to transcribe voice input locally with Whisper.",
        "LSUIElement": true
      }
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "node-addon-api": "^8.3.0",
    "node-gyp": "^11.2.0",
    "postcss": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10"
  }
}
